# ─── MariaDB ───────────────────────────────────────────
MARIADB_ROOT_PASSWORD=rootpass

# Base de datos de la app de inventario
MARIADB_DATABASE=eskol_db
MARIADB_USER=talleruser
MARIADB_PASSWORD=tallerpass

# Base de datos de WordPress (mismo servidor MariaDB)
